# Root env — needed for the SST CLI (sst dev / deploy / secret).
# Copy to .env and fill in. Do NOT commit .env.
#
# AWS credentials are NOT set here — SST reads them from the standard
# AWS SDK chain (~/.aws/credentials or AWS_* env vars). Set those separately.

# Cloudflare provider (sst.config.ts) — DNS for the prod domains.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=

# --- Reference only: app secrets live in AWS SSM, NOT in this file. ---
# Set/rotate them with the SST CLI, per stage:
#   sst secret set AlertEmail           <value> --stage prod
#   sst secret set DbUrl                <value> --stage prod
#   sst secret set ClerkSigningSecret   <value> --stage prod
#   sst secret set ClerkSecretKey       <value> --stage prod
#   sst secret set ClerkPublishableKey  <value> --stage prod
# List current:   sst secret list --stage prod
